<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Button?>

<AnchorPane fx:id="panelFondo" id="panelFondo"
	stylesheets="@Partida.css" xmlns="http://javafx.com/javafx/21"
	xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="controlador.ControladorVentanaDePartida">

	<children>

		<GridPane fx:id="gridTablero" />

		<HBox fx:id="barraInferior" spacing="15" alignment="CENTER_LEFT"
			AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0"
			AnchorPane.bottomAnchor="43.0">

			<children>

				<Button fx:id="btnAbrirMazoPropio" styleClass="mazo-propio"
					prefWidth="160.0" prefHeight="200.0" minWidth="160.0"
					minHeight="200.0" maxWidth="160.0" maxHeight="200.0" />

				<Button fx:id="btnAbrirMazoObjetivo" styleClass="mazo-target"
					prefWidth="160.0" prefHeight="200.0" minWidth="160.0"
					minHeight="200.0" maxWidth="160.0" maxHeight="200.0" />

				<Button fx:id="btnAbrirMazoGlobal" styleClass="mazo-global"
					prefWidth="160.0" prefHeight="200.0" minWidth="160.0"
					minHeight="200.0" maxWidth="160.0" maxHeight="200.0" />

				<Button fx:id="btnAbrirMazoMaestro" styleClass="mazo-maestro"
					prefWidth="160.0" prefHeight="200.0" minWidth="160.0"
					minHeight="200.0" maxWidth="160.0" maxHeight="200.0" />

				<Pane HBox.hgrow="ALWAYS" />

				<Button fx:id="btnLanzarDado" text="Dado"
					styleClass="boton-dado" prefWidth="240.0" prefHeight="140.0"
					minWidth="240.0" minHeight="140.0" maxWidth="240.0"
					maxHeight="140.0" />

			</children>
		</HBox>

	</children>
</AnchorPane>
