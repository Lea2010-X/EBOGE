<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<AnchorPane fx:id="panelFondo" id="panelFondo"
    stylesheets="@Partida.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controlador.ControladorVentanaDePartida">

    <children>

        <!-- TABLERO -->
        <GridPane fx:id="gridTablero" />

        <!-- BARRA INFERIOR -->
        <HBox fx:id="barraInferior" spacing="15" alignment="CENTER"
              AnchorPane.leftAnchor="40.0" AnchorPane.rightAnchor="40.0"
              AnchorPane.bottomAnchor="43.0">

            <children>

                <!-- Mazos -->
                <Button fx:id="btnAbrirMazoPropio" styleClass="mazo-propio"
                        prefWidth="160" prefHeight="200" />

                <Button fx:id="btnAbrirMazoObjetivo" styleClass="mazo-target"
                        prefWidth="160" prefHeight="200" />

                <Button fx:id="btnAbrirMazoGlobal" styleClass="mazo-global"
                        prefWidth="160" prefHeight="200" />

                <Button fx:id="btnAbrirMazoMaestro" styleClass="mazo-maestro"
                        prefWidth="160" prefHeight="200" />

                <!-- separador flexible -->
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Bloque CENTRADO: Turno de / Nombre -->
                <VBox alignment="CENTER" spacing="6">
                    <children>
                        <Label fx:id="lblTurnoTexto" text="Turno de:" styleClass="turno-texto" />
                        <Label fx:id="lblNombreJugador" text="Jugador" styleClass="turno-nombre" />
                    </children>
                </VBox>

                <!-- separador flexible -->
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Bloque resultado + botón dado -->
                <VBox alignment="CENTER" spacing="10">
                    <children>
                        <Label fx:id="lblResultadoDado" text="-" styleClass="resultado-dado" />
                        <Button fx:id="btnLanzarDado" text="Dado"
                                styleClass="boton-dado"
                                prefWidth="240" prefHeight="140" />
                    </children>
                </VBox>

            </children>
        </HBox>


        <!-- ========================================================= -->
        <!-- 🔥 OVERLAY DE CARTA EN GRANDE (NUEVO)                    -->
        <!-- ========================================================= -->
        <StackPane fx:id="overlayCarta"
                   visible="false" managed="false"
                   style="-fx-background-color: rgba(0,0,0,0.65);"
                   AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
                   AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

            <children>

                <!-- Botón que muestra la carta grande -->
                <Button fx:id="btnCartaGrande"
                        prefWidth="600" prefHeight="850"
                        style="-fx-background-color: transparent;
                               -fx-background-size: contain;
                               -fx-background-position: center;
                               -fx-background-repeat: no-repeat;" />

            </children>

        </StackPane>

    </children>
</AnchorPane>