<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controlador.ControladorConfiguracion"
            prefWidth="1000.0" prefHeight="700.0"
            styleClass="fondo-configuracion"
            stylesheets="@Configuracion.css">

    <!-- ENCABEZADO -->
    <top>
        <HBox alignment="CENTER" prefHeight="100.0">
            <Label text="EBOGE" styleClass="titulo-pixel"/>
        </HBox>
    </top>

    <!-- CENTRO -->
    <center>
        <HBox alignment="CENTER" spacing="50.0">
            <padding>
                <Insets top="20" right="50" bottom="20" left="50"/>
            </padding>

            <!-- PANEL IZQUIERDO: LISTA JUGADORES -->
            <VBox spacing="10.0" prefWidth="350.0" HBox.hgrow="ALWAYS">
                <Label text="Jugadores" styleClass="subtitulo-pixel"/>
                
                <VBox styleClass="contenedor-lista" VBox.vgrow="ALWAYS" spacing="10.0">
                    <padding>
                        <Insets top="15" right="15" bottom="15" left="15"/>
                    </padding>
                    
                    <ScrollPane fitToWidth="true" styleClass="scroll-pixel" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="contenedorJugadores" spacing="10.0"/>
                        </content>
                    </ScrollPane>
                </VBox>
            </VBox>

            <!-- PANEL DERECHO: FORMULARIOS -->
            <VBox spacing="40.0" prefWidth="450.0" HBox.hgrow="ALWAYS" alignment="TOP_LEFT">
                
                <!-- AGREGAR JUGADOR -->
                <VBox spacing="20.0">
                    <Label text="Agregar jugador" styleClass="subtitulo-pixel"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <Label text="Nombre" styleClass="etiqueta-pixel" prefWidth="120.0"/>
                        <TextField fx:id="txtNombre" styleClass="input-pixel" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <Label text="Color" styleClass="etiqueta-pixel" prefWidth="120.0"/>
                        <ComboBox fx:id="cboxColor" styleClass="combo-pixel" prefWidth="150.0"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Agregar" onAction="#agregarJugador" styleClass="boton-pixel-pequeno"/>
                    </HBox>
                </VBox>

                <!-- CONFIGURAR DADO -->
                <VBox spacing="20.0">
                    <Label text="Configurar dado" styleClass="subtitulo-pixel"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <Label text="Tipo" styleClass="etiqueta-pixel" prefWidth="120.0"/>
                        <ComboBox fx:id="cboxDado" styleClass="combo-pixel" prefWidth="150.0"/>
                    </HBox>
                </VBox>

                <!-- BOTON INICIAR -->
                <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                    <Button text="INICIAR" onAction="#iniciarPartida" styleClass="boton-pixel-grande"/>
                </VBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>